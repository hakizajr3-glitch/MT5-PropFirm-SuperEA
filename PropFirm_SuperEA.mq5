//+------------------------------------------------------------------+\n//|                                                      PropFirm_SuperEA.mq5 |\n//|                        Copyright 2026, MetaTrader 5              |\n//|                                       https://www.mql5.com       |\n//+------------------------------------------------------------------+\ninput double TakeProfit = 50;   // Take Profit in points\ninput double StopLoss = 50;      // Stop Loss in points\ninput double LotSize = 0.1;      // Lot size\ninput int Slippage = 3;          // Slippage\n\n//+------------------------------------------------------------------+\n//| Custom indicator iteration                                       |\n//+------------------------------------------------------------------+\nint OnInit()\n{\n    // Initialization code\n    Print("PropFirm_SuperEA initialized");\n    return INIT_SUCCEEDED;\n}\n\n//+------------------------------------------------------------------+\n//| Expert tick function                                            |\n//+------------------------------------------------------------------+\nvoid OnTick()\n{\n    // Trading logic\n    double Bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);\n    double Ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);\n\n    // Example logic for opening a buy order\n    if (true) // Replace with your entry condition\n    {\n        OpenBuyOrder(Ask);\n    }\n\n    // Example logic for opening a sell order\n    if (false) // Replace with your entry condition\n    {\n        OpenSellOrder(Bid);\n    }\n}\n\n//+------------------------------------------------------------------+\n//| Function to open buy order                                      |\n//+------------------------------------------------------------------+\nvoid OpenBuyOrder(double price)\n{\n    double stopLossPrice = price - StopLoss * Point;\n    double takeProfitPrice = price + TakeProfit * Point;\n    \n    int ticket = OrderSend(_Symbol, OP_BUY, LotSize, price, Slippage, stopLossPrice, takeProfitPrice, "Buy Order", 0, 0, clrGreen);\n    if(ticket < 0)\n        Print("Error opening buy order: ", GetLastError());\n}\n\n//+------------------------------------------------------------------+\n//| Function to open sell order                                     |\n//+------------------------------------------------------------------+\nvoid OpenSellOrder(double price)\n{\n    double stopLossPrice = price + StopLoss * Point;\n    double takeProfitPrice = price - TakeProfit * Point;\n    \n    int ticket = OrderSend(_Symbol, OP_SELL, LotSize, price, Slippage, stopLossPrice, takeProfitPrice, "Sell Order", 0, 0, clrRed);\n    if(ticket < 0)\n        Print("Error opening sell order: ", GetLastError());\n}\n\n//+------------------------------------------------------------------+\n//| Cleanup function                                               |\n//+------------------------------------------------------------------+\nvoid OnDeinit(const int reason)\n{\n    // Cleanup code\n    Print("PropFirm_SuperEA deinitialized");\n}\n//+------------------------------------------------------------------+